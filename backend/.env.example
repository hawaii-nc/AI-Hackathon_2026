# Copy this file to .env and fill in real values.
# Everything here is OPTIONAL for local testing:
#   - Without GEMINI_API_KEY, the referral email uses a template fallback.
#   - Without SUPABASE_*, use the mock data path in test_referral_local.py.

# --- AI ---
GEMINI_API_KEY=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Google Cloud ---
GOOGLE_APPLICATION_CREDENTIALS=adc.json
GOOGLE_PROJECT_ID=
GOOGLE_PROCESSOR_ID=
GOOGLE_PROCESSOR_LOCATION=us

# --- Email sending ---
# console = save + preview locally (default, no network, great for testing)
# smtp    = send through an SMTP server (local catcher or real provider)
EMAIL_BACKEND=console

# Only used when EMAIL_BACKEND=smtp.
# Local catcher:  python -m aiosmtpd -n -l localhost:1025  (host=localhost port=1025)
# Gmail:          host=smtp.gmail.com  port=587  use_tls=true
#                 user=you@gmail.com   password=<16-char App Password, 2FA required>
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false

# Optional: force the visible "From" (Gmail only sends from the logged-in
# account, so set these to your Gmail address for a clean From line).
MAIL_FROM=
MAIL_FROM_NAME=
